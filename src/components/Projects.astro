      github: 'https://github.com/Proftg/migraine-tracker',
      featured: true,
    },
    {
      title: 'Bank Customer Data Preparation',
      description: 'Comprehensive data preparation and cleaning pipeline for bank customer datasets. ETL processes, data quality assessment, and feature preparation for downstream ML models.',
      tags: ['Python', 'Pandas', 'NumPy', 'Data Cleaning', 'ETL'],
      github: 'https://github.com/Proftg/Bank-Customer-Data-Prep',
    },
    {
      title: 'Le Wagon — Data Science Final Project',
      description: 'Capstone project for Le Wagon Data Science & AI bootcamp (400h+). Full team project covering Machine Learning, Deep Learning, Data Engineering, and MLOps deployment.',
      tags: ['Python', 'Deep Learning', 'MLOps', 'Docker', 'Team Project'],
    },
    {
      title: 'Board Game Popularity Analysis',
      description: 'Predictive modeling of popularity factors from data enriched via API. External data enrichment via REST API, feature engineering and cross-validation.',
      tags: ['Python', 'NumPy', 'Seaborn', 'API REST', 'Streamlit'],
      github: 'https://github.com/Proftg/BGG-Project---Board-Game-Analysis',
