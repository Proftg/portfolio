  ],
  fr: [
    {
      title: 'Blackspots — Cartographie des Retards Ferroviaires',
      description: 'Analyse géospatiale de 22,6 millions d\'enregistrements ferroviaires Infrabel. Heatmap Folium interactive identifiant les points chauds de retards sur le réseau belge. Analyse de tendance mensuelle avec Plotly, dashboard Streamlit, et pipeline de données réduisant 5 Go à 1,1 Go via optimisation catégorielle.',
      tags: ['Python', 'Pandas', 'Folium', 'Plotly', 'Streamlit', 'Géospatial'],
