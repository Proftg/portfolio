    {
      title: 'Le Wagon — Eindproject Data Science',
      description: 'Eindproject voor Le Wagon Data Science & AI bootcamp (400+ uur). Volledig teamproject met Machine Learning, Deep Learning, Data Engineering en MLOps deployment.',
      tags: ['Python', 'Deep Learning', 'MLOps', 'Docker', 'Teamproject'],
    },
    {
      title: 'Bordspel Populariteitsanalyse',
      description: 'Voorspellende modellering van populariteitsfactoren uit data verrijkt via API. Feature engineering en kruisvalidatie.',
      tags: ['Python', 'NumPy', 'Seaborn', 'API REST', 'Streamlit'],
      github: 'https://github.com/Proftg/BGG-Project---Board-Game-Analysis',
    },
  ],
};

const currentProjects = projects[lang] || projects.en;
---

<section class="section" id="projects">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <h2 class="section-title">{t('projects.title')}</h2>
      <p class="section-subtitle">{t('projects.subtitle')}</p>
    </div>

    <div class="projects-grid">
      {currentProjects.map((project, i) => (
        <div class={`project-card animate-on-scroll`} style={`transition-delay: ${i * 100}ms`}>
          <div class="project-card-image-placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
              <polyline points="7.5 4.21 12 6.81 16.5 4.21"/>
              <polyline points="7.5 19.79 7.5 14.6 3 12"/>
              <polyline points="21 12 16.5 14.6 16.5 19.79"/>
              <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
              <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
          </div>
          <div class="project-card-body">
            {project.featured && (
              <span class="project-card-featured">
                ★ Featured
              </span>
            )}
            <h3 class="project-card-title">{project.title}</h3>
            <p class="project-card-description">{project.description}</p>
            <div class="project-card-tags">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <div class="project-card-links">
              {project.github && (
                <a href={project.github} target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                  {t('projects.viewCode')}
                </a>
              )}
              {project.live && (
                <a href={project.live} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  {t('projects.viewLive')}
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
