---
import { getLangFromUrl, useTranslations } from '../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Project {
  title: string;
  description: string;
  tags: string[];
  github?: string;
  live?: string;
  featured?: boolean;
}

const projects: Record<string, Project[]> = {
  en: [
    {
      title: 'Blackspots — Railway Delay Cartography',
      description: 'Geospatial analysis of 19.7 million train records from Infrabel Open Data (Jan 2025 – Feb 2026). Interactive Folium heatmap identifying delay hotspots across 500 Belgian stations. Monthly trend analysis with Plotly, Streamlit dashboard, and optimized Parquet data pipeline.',
      tags: ['Python', 'Pandas', 'Folium', 'Plotly', 'Streamlit', 'Geospatial'],
      github: 'https://github.com/Proftg/blackspots-infrabel',
      live: 'https://blackspots-infrabel.streamlit.app/',
      featured: true,
    },
    {
      title: 'Railway Delay ML — Predictive Modeling',
      description: 'End-to-end ML pipeline on 19.7M Infrabel Open Data records. Geographic clustering (DBSCAN haversine, 28 basins), anomaly detection (Isolation Forest, 50 stations), temporal decomposition (STL weekly), and multi-model comparison (XGBoost · GradientBoosting · RandomForest · Stacking). 5-Fold CV with sklearn Pipeline — no data leakage. AUC=0.813 · MAE=0.275 min (cross-validated).',
      tags: ['Python', 'XGBoost', 'Scikit-learn', 'DBSCAN', 'Isolation Forest', 'STL', 'Cross-Validation'],
      github: 'https://github.com/Proftg/railway-delay-ml',
      featured: true,
    },
    {
      title: 'Infrabel Dashboard — KPI Qualité Réseau',
      description: 'Dashboard interactif de ponctualité et fiabilité du réseau ferroviaire belge. 5 datasets Open Data Infrabel (ponctualité par gare, causes des retards, trains supprimés, Contrat de Performance). Notebook ETL/EDA complet + Streamlit + Power BI.',
      tags: ['Python', 'Pandas', 'Plotly', 'Streamlit', 'Power BI', 'Open Data'],
      github: 'https://github.com/Proftg/infrabel-dashboard',
      live: 'https://infrabel-dashboard.streamlit.app/',
      featured: true,
    },
    {
      title: 'SNCB Live Dashboard',
      description: 'Real-time dashboard monitoring Belgian railway punctuality across 20 major stations. Live data from iRail API (parallel fetch via ThreadPoolExecutor), GPS coordinates extracted directly from API response. KPI gauges, Folium interactive map, Plotly heatmap, delay distribution, auto-refresh every 60s. Jupyter notebook with 12 analysis sections.',
      tags: ['Python', 'Streamlit', 'Plotly', 'Folium', 'iRail API', 'Real-time', 'Pandas'],
      github: 'https://github.com/Proftg/sncb-live-dashboard',
      live: 'https://sncb-live-dashboard.streamlit.app/',
      featured: true,
    },
    {
      title: 'Bank Customer Churn Prediction',
      description: 'End-to-end ML pipeline to predict customer churn in banking. Identified 3 key factors impacting 40% of at-risk customers using behavioral analysis of 10,000+ users. Built predictive models (Random Forest, Logistic Regression) with advanced feature engineering.',
      tags: ['Python', 'Pandas', 'Scikit-learn', 'Streamlit', 'Feature Engineering'],
      github: 'https://github.com/Proftg/Bank-Customer-Churn',
      featured: true,
    },
    {
      title: 'Maven Music — Churn Analysis',
      description: 'Customer churn analysis for a music streaming platform. Reduction of customer attrition via behavioral analysis of 10,000+ users. Deployed interactive Streamlit dashboard accessible online.',
      tags: ['Python', 'Scikit-learn', 'Matplotlib', 'Seaborn', 'Streamlit'],
      github: 'https://github.com/Proftg/maven_music_streamlit-app',
      live: 'https://maven-music-app.streamlit.app/',
      featured: true,
    },
    {
      title: 'Bank Customer Data Preparation',
      description: 'Comprehensive data preparation and cleaning pipeline for bank customer datasets. ETL processes, data quality assessment, and feature preparation for downstream ML models.',
      tags: ['Python', 'Pandas', 'NumPy', 'Data Cleaning', 'ETL'],
      github: 'https://github.com/Proftg/Bank-Customer-Data-Prep',
    },
    {
      title: 'Le Wagon — Board Game Popularity Analysis',
      description: 'Capstone project for Le Wagon Data Science & AI bootcamp (400h+). Predictive modeling of board game popularity from 20,000+ BGG records enriched via REST API. Feature engineering, cross-validation, and Streamlit dashboard deployment.',
      tags: ['Python', 'Scikit-learn', 'NumPy', 'Seaborn', 'API REST', 'Streamlit'],
      github: 'https://github.com/Proftg/BGG-Project---Board-Game-Analysis',
    },
  ],
  fr: [
    {
      title: 'Blackspots — Cartographie des Retards Ferroviaires',
      description: 'Analyse géospatiale de 19,7 millions d\'enregistrements Open Data Infrabel (jan 2025 – fév 2026). Heatmap Folium interactive identifiant les points chauds de retards sur 500 gares belges. Analyse de tendance mensuelle avec Plotly, dashboard Streamlit et pipeline Parquet optimisé.',
      tags: ['Python', 'Pandas', 'Folium', 'Plotly', 'Streamlit', 'Géospatial'],
      github: 'https://github.com/Proftg/blackspots-infrabel',
      live: 'https://blackspots-infrabel.streamlit.app/',
      featured: true,
    },
    {
      title: 'Railway Delay ML — Modélisation Prédictive',
      description: 'Pipeline ML complet sur 19,7M d\'enregistrements Open Data Infrabel. Clustering géographique (DBSCAN haversine, 28 bassins), détection d\'anomalies (Isolation Forest, 50 gares), décomposition temporelle (STL hebdomadaire), comparaison multi-modèles (XGBoost · GradientBoosting · RandomForest · Stacking). Validation croisée 5 folds avec Pipeline sklearn — sans data leakage. AUC=0.813 · MAE=0.275 min (cross-validé).',
      tags: ['Python', 'XGBoost', 'Scikit-learn', 'DBSCAN', 'Isolation Forest', 'STL', 'Validation Croisée'],
      github: 'https://github.com/Proftg/railway-delay-ml',
      featured: true,
    },
    {
      title: 'Infrabel Dashboard — KPI Qualité Réseau',
      description: 'Dashboard interactif de ponctualité et fiabilité du réseau ferroviaire belge. 5 datasets Open Data Infrabel (ponctualité par gare, causes des retards, trains supprimés, Contrat de Performance). Notebook ETL/EDA complet + Streamlit + Power BI.',
      tags: ['Python', 'Pandas', 'Plotly', 'Streamlit', 'Power BI', 'Open Data'],
      github: 'https://github.com/Proftg/infrabel-dashboard',
      live: 'https://infrabel-dashboard.streamlit.app/',
      featured: true,
    },
    {
      title: 'SNCB Live Dashboard',
      description: 'Dashboard temps réel de ponctualité ferroviaire belge sur 20 gares majeures. Données live via iRail API (fetch parallèle ThreadPoolExecutor), coordonnées GPS extraites directement de la réponse API. Jauges KPI, carte Folium interactive, heatmap Plotly, distribution des retards, auto-refresh 60s. Notebook Jupyter avec 12 sections d\'analyse.',
      tags: ['Python', 'Streamlit', 'Plotly', 'Folium', 'iRail API', 'Temps réel', 'Pandas'],
      github: 'https://github.com/Proftg/sncb-live-dashboard',
      live: 'https://sncb-live-dashboard.streamlit.app/',
      featured: true,
    },
    {
      title: 'Prédiction de Churn Client Bancaire',
      description: 'Pipeline ML de bout en bout pour prédire l\'attrition client dans le secteur bancaire. Identification de 3 facteurs clés impactant 40% des clients à risque via l\'analyse comportementale de 10 000+ utilisateurs.',
      tags: ['Python', 'Pandas', 'Scikit-learn', 'Streamlit', 'Feature Engineering'],
      github: 'https://github.com/Proftg/Bank-Customer-Churn',
      featured: true,
    },
    {
      title: 'Maven Music — Analyse de Churn',
      description: 'Analyse d\'attrition client pour une plateforme de streaming musical. Réduction de l\'attrition via l\'analyse comportementale de 10 000+ utilisateurs. Dashboard interactif Streamlit déployé en ligne.',
      tags: ['Python', 'Scikit-learn', 'Matplotlib', 'Seaborn', 'Streamlit'],
      github: 'https://github.com/Proftg/maven_music_streamlit-app',
      live: 'https://maven-music-app.streamlit.app/',
      featured: true,
    },
    {
      title: 'Préparation de Données Client Bancaire',
      description: 'Pipeline complet de préparation et nettoyage de données pour les datasets clients bancaires. Processus ETL, évaluation de la qualité des données et préparation de features.',
      tags: ['Python', 'Pandas', 'NumPy', 'Data Cleaning', 'ETL'],
      github: 'https://github.com/Proftg/Bank-Customer-Data-Prep',
    },
    {
      title: 'Le Wagon — Analyse de Popularité des Jeux de Société',
      description: 'Projet de fin de formation Le Wagon Data Science & AI (400h+). Modélisation prédictive de la popularité de jeux de société à partir de 20 000+ records BGG enrichis via API REST. Feature engineering, validation croisée et déploiement Streamlit.',
      tags: ['Python', 'Scikit-learn', 'NumPy', 'Seaborn', 'API REST', 'Streamlit'],
      github: 'https://github.com/Proftg/BGG-Project---Board-Game-Analysis',
    },
  ],
  nl: [
    {
      title: 'Blackspots — Spoorwegvertraging Cartografie',
      description: 'Geospatiale analyse van 19,7 miljoen Infrabel Open Data records (jan 2025 – feb 2026). Interactieve Folium heatmap die vertragingshotspots in 500 Belgische stations identificeert. Maandelijkse trendanalyse met Plotly, Streamlit dashboard en geoptimaliseerde Parquet pipeline.',
      tags: ['Python', 'Pandas', 'Folium', 'Plotly', 'Streamlit', 'Geospatial'],
      github: 'https://github.com/Proftg/blackspots-infrabel',
      live: 'https://blackspots-infrabel.streamlit.app/',
      featured: true,
    },
    {
      title: 'Railway Delay ML — Voorspellende Modellering',
      description: 'End-to-end ML-pipeline op 19,7M Infrabel Open Data records. Geografische clustering (DBSCAN haversine, 28 bassins), anomaliedetectie (Isolation Forest, 50 stations), temporele decompositie (STL wekelijks), multi-model vergelijking (XGBoost · GradientBoosting · RandomForest · Stacking). 5-voudige kruisvalidatie met sklearn Pipeline — geen data leakage. AUC=0,813 · MAE=0,275 min (kruisgevalideerd).',
      tags: ['Python', 'XGBoost', 'Scikit-learn', 'DBSCAN', 'Isolation Forest', 'STL', 'Kruisvalidatie'],
      github: 'https://github.com/Proftg/railway-delay-ml',
      featured: true,
    },
    {
      title: 'Infrabel Dashboard — KPI Netwerkkwaliteit',
      description: 'Interactief dashboard voor stiptheid en betrouwbaarheid van het Belgische spoornetwerk. 5 Open Data Infrabel datasets (stiptheid per station, vertragingsoorzaken, geschrapted treinen, Prestatiecontract). Volledige ETL/EDA notebook + Streamlit + Power BI.',
      tags: ['Python', 'Pandas', 'Plotly', 'Streamlit', 'Power BI', 'Open Data'],
      github: 'https://github.com/Proftg/infrabel-dashboard',
      live: 'https://infrabel-dashboard.streamlit.app/',
      featured: true,
    },
    {
      title: 'SNCB Live Dashboard',
      description: 'Realtime stiptheidsdashboard voor het Belgische spoorwegnetwerk over 20 grote stations. Live data via iRail API (parallelle fetch via ThreadPoolExecutor), GPS-coördinaten rechtstreeks uit API-respons. KPI-meters, interactieve Folium kaart, Plotly heatmap, vertragingsdistributie, auto-refresh 60s. Jupyter notebook met 12 analysesecties.',
      tags: ['Python', 'Streamlit', 'Plotly', 'Folium', 'iRail API', 'Realtime', 'Pandas'],
      github: 'https://github.com/Proftg/sncb-live-dashboard',
      live: 'https://sncb-live-dashboard.streamlit.app/',
      featured: true,
    },
    {
      title: 'Bankklant Churn Voorspelling',
      description: 'End-to-end ML-pipeline om klantenverloop in het bankwezen te voorspellen. 3 sleutelfactoren geïdentificeerd die 40% van de risicokanten beïnvloeden via gedragsanalyse van 10.000+ gebruikers.',
      tags: ['Python', 'Pandas', 'Scikit-learn', 'Streamlit', 'Feature Engineering'],
      github: 'https://github.com/Proftg/Bank-Customer-Churn',
      featured: true,
    },
    {
      title: 'Maven Music — Churn Analyse',
      description: 'Klantenverloop analyse voor een muziek streaming platform. Reductie van klantverloop via gedragsanalyse van 10.000+ gebruikers. Interactief Streamlit dashboard online beschikbaar.',
      tags: ['Python', 'Scikit-learn', 'Matplotlib', 'Seaborn', 'Streamlit'],
      github: 'https://github.com/Proftg/maven_music_streamlit-app',
      live: 'https://maven-music-app.streamlit.app/',
      featured: true,
    },
    {
      title: 'Bankklant Datacleaning',
      description: 'Uitgebreide data voorbereiding en schoonmaak pipeline voor bankklant datasets. ETL-processen, datakwaliteitsbeoordeling en feature voorbereiding.',
      tags: ['Python', 'Pandas', 'NumPy', 'Data Cleaning', 'ETL'],
      github: 'https://github.com/Proftg/Bank-Customer-Data-Prep',
    },
    {
      title: 'Le Wagon — Bordspel Populariteitsanalyse',
      description: 'Eindproject voor Le Wagon Data Science & AI bootcamp (400+ uur). Voorspellende modellering van bordspelpopulariteit uit 20.000+ BGG-records verrijkt via REST API. Feature engineering, kruisvalidatie en Streamlit deployment.',
      tags: ['Python', 'Scikit-learn', 'NumPy', 'Seaborn', 'API REST', 'Streamlit'],
      github: 'https://github.com/Proftg/BGG-Project---Board-Game-Analysis',
    },
  ],
};

const currentProjects = projects[lang] || projects.en;
---

<section class="section" id="projects">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <h2 class="section-title">{t('projects.title')}</h2>
      <p class="section-subtitle">{t('projects.subtitle')}</p>
    </div>

    <div class="projects-grid">
      {currentProjects.map((project, i) => (
        <div class={`project-card animate-on-scroll`} style={`transition-delay: ${i * 100}ms`}>
          <div class="project-card-image-placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
              <polyline points="7.5 4.21 12 6.81 16.5 4.21"/>
              <polyline points="7.5 19.79 7.5 14.6 3 12"/>
              <polyline points="21 12 16.5 14.6 16.5 19.79"/>
              <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
              <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
          </div>
          <div class="project-card-body">
            {project.featured && (
              <span class="project-card-featured">
                ★ Featured
              </span>
            )}
            <h3 class="project-card-title">{project.title}</h3>
            <p class="project-card-description">{project.description}</p>
            <div class="project-card-tags">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <div class="project-card-links">
              {project.github && (
                <a href={project.github} target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                  {t('projects.viewCode')}
                </a>
              )}
              {project.live && (
                <a href={project.live} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  {t('projects.viewLive')}
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
