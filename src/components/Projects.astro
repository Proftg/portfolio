  ],
  nl: [
    {
      title: 'Blackspots — Spoorwegvertraging Cartografie',
      description: 'Geospatiale analyse van 22,6 miljoen treinrecords van Infrabel. Interactieve Folium heatmap die vertragingshotspots in het Belgische netwerk identificeert. Maandelijkse trendanalyse met Plotly, Streamlit dashboard, en datapijplijn die 5 GB reduceert tot 1,1 GB via categorische optimalisatie.',
      tags: ['Python', 'Pandas', 'Folium', 'Plotly', 'Streamlit', 'Geospatial'],
      github: 'https://github.com/Proftg/blackspots-infrabel',
      live: 'https://blackspots-infrabel.streamlit.app/',
      featured: true,
    },
    {
      title: 'Infrabel Dashboard — KPI Netwerkkwaliteit',
      description: 'Interactief dashboard voor stiptheid en betrouwbaarheid van het Belgische spoornetwerk. 5 Open Data Infrabel datasets (stiptheid per station, vertragingsoorzaken, geschrapted treinen, Prestatiecontract). Volledige ETL/EDA notebook + Streamlit + Power BI.',
      tags: ['Python', 'Pandas', 'Plotly', 'Streamlit', 'Power BI', 'Open Data'],
      github: 'https://github.com/Proftg/infrabel-dashboard',
      live: 'https://infrabel-dashboard.streamlit.app/',
      featured: true,
    },
    {
      title: 'SNCB Live Dashboard',
