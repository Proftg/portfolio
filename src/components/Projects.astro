      description: 'Klantenverloop analyse voor een muziek streaming platform. Reductie van klantverloop via gedragsanalyse van 10.000+ gebruikers. Interactief Streamlit dashboard online beschikbaar.',
      tags: ['Python', 'Scikit-learn', 'Matplotlib', 'Seaborn', 'Streamlit'],
      github: 'https://github.com/Proftg/maven_music_streamlit-app',
      live: 'https://maven-music-app.streamlit.app/',
      featured: true,
    },
